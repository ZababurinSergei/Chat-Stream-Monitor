{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "*.config.ts"],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "outDir": "./dist",
        "declaration": true,
        "declarationDir": "./dist/types",
        "emitDeclarationOnly": false,
        "composite": false,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "node"]
    }
}
