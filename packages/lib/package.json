{
  "name": "@infoenergo/infoenergo-ui",
  "version": "0.0.25-dev",
  "type": "module",
  "description": "Библиотека UI-компонентов ASUSE.AI",
  "main": "./dist/infoenergo-ui.cjs",
  "module": "./dist/infoenergo-ui.mjs",
  "files": [
    "dist"
  ],
  "types": "./dist/types/public-types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/public-types.d.ts",
      "import": "./dist/infoenergo-ui.mjs",
      "require": "./dist/infoenergo-ui.cjs"
    },
    "./styles": "./dist/infoenergo-ui.css"
  },
  "publishConfig": {
    "@infoenergo:registry": "http://gitlab.infoenergo.loc/api/v4/projects/508/packages/npm/"
  },
  "repository": {
    "type": "git",
    "url": "http://gitlab.infoenergo.loc/infoenergo.npm/infoenergo-ui.git"
  },
  "author": "infoenergo",
  "license": "ISC",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "vite build && npm run build:types",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "sb": "storybook dev -p 6006",
    "build-sb": "storybook build",
    "preview-sb": "vite preview --outDir storybook-static --port 6006",
    "test": "vitest",
    "dev": "vite build --watch",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:eslint": "eslint . --ext .js,.ts,.vue",
    "lint:prettier": "prettier --check .",
    "lint:ci": "npm run lint:eslint && npm run lint:prettier"
  },
  "peerDependencies": {
    "naive-ui": "2.44.x",
    "vue": "3.5.x"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@storybook/addon-a11y": "10.2.5",
    "@storybook/addon-docs": "10.2.5",
    "@storybook/vue3-vite": "10.2.5",
    "@testing-library/vue": "8.1.0",
    "@types/node": "22.10.6",
    "@vitejs/plugin-vue": "6.0.2",
    "@vitejs/plugin-vue-jsx": "5.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/eslint-config-typescript": "14.6.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.8.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.2.5",
    "eslint-plugin-vue": "10.6.2",
    "globals": "17.2.0",
    "happy-dom": "20.4.0",
    "naive-ui": "2.44.1",
    "prettier": "3.7.4",
    "sass-embedded": "^1.97.3",
    "storybook": "10.2.5",
    "typescript": "5.8.3",
    "typescript-eslint": "8.54.0",
    "vite": "6.4.1",
    "vite-plugin-vue-devtools": "8.0.5",
    "vitest": "4.0.18",
    "vue": "3.5.25",
    "vue-tsc": "2.2.0"
  }
}
