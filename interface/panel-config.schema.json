{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quantum Git Panel Configuration",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "defaultPreset": {
      "type": "string"
    },
    "presets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/preset"
      }
    }
  },
  "definitions": {
    "preset": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "layout": {
          "$ref": "#/definitions/panelLayout"
        }
      },
      "required": ["name", "layout"]
    }
  }
}