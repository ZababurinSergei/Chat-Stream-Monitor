{
  "name": "@newkind/chat-stream-monitor",
  "version": "0.0.2",
  "type": "module",
  "private": true,
  "description": "Monorepo for AST Analyzer and FS Scanner tools",
  "main": "main.mjs",
  "scripts": {
    "start": "node main.mjs",
    "scan": "node main.mjs",
    "config": "node generate-config.mjs",
    "license:add": "node check-license.mjs add",
    "license:check": "node check-license.mjs check",
    "license:verify": "node check-license.mjs verify",
    "license:help": "node check-license.mjs help",
    "precommit": "npm run license:check",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=./packages/* && changeset publish"
  },
  "keywords": [
    "scanner",
    "filesystem",
    "json",
    "configurable",
    "monorepo",
    "ast-analyzer",
    "fs-scanner",
    "turborepo"
  ],
  "author": "Забабурин Сергей <zababurins@vk.com>",
  "license": "CSL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZababurinSergei/Chat-Stream-Monitor"
  },
  "homepage": "https://github.com/ZababurinSergei/Chat-Stream-Monitor#readme",
  "bugs": {
    "url": "https://github.com/ZababurinSergei/Chat-Stream-Monitor/issues"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.22.0",
    "@typescript-eslint/parser": "^8.61.0",
    "estree-walker": "^3.0.3",
    "glob": "^13.0.6"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "turbo": "^2.9.17",
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
