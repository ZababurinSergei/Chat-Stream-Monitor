{
  "name": "@newkind/chat-stream-monitor",
  "version": "0.0.2",
  "type": "module",
  "private": true,
  "description": "Monorepo for AST Analyzer and FS Scanner tools",
  "main": "main.mjs",
  "scripts": {
    "scan": "node main.mjs",
    "dev": "turbo dev",
    "build": "turbo build",
    "build:ast": "cd packages/ast-analyzer && pnpm build",
    "build:shared": "cd packages/shared-types && pnpm build",
    "test": "turbo test",
    "test:ast": "cd packages/ast-analyzer && pnpm test",
    "test:shared": "cd packages/shared-types && pnpm test",
    "test:coverage": "turbo test:coverage",
    "lint": "pnpm run lint:ast && pnpm run lint:shared && pnpm run lint:tooling",
    "lint:ast": "eslint packages/ast-analyzer/src/**/*.{ts,tsx} --cache",
    "lint:shared": "eslint packages/shared-types/src/**/*.ts --cache",
    "lint:tooling": "eslint tooling/**/*.js --cache",
    "lint:fix": "pnpm run lint:ast --fix && pnpm run lint:shared --fix && pnpm run lint:tooling --fix",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "clean:ast": "cd Directory/ast-analyzer && pnpm clean",
    "clean:shared": "cd packages/shared-types && pnpm clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=./packages/* && changeset publish",
    "prepare": "husky",
    "config": "node generate-config.mjs",
    "license:add": "node check-license.mjs add",
    "license:check": "node check-license.mjs check",
    "license:verify": "node check-license.mjs verify",
    "license:help": "node check-license.mjs help",
    "precommit": "npm run license:check",
    "preinstall": "node scripts/check-pnpm.mjs"
  },
  "keywords": [
    "scanner",
    "filesystem",
    "json",
    "configurable",
    "monorepo",
    "ast-analyzer",
    "fs-scanner",
    "turborepo"
  ],
  "author": "Забабурин Сергей <zababurins@vk.com>",
  "license": "CSL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZababurinSergei/Chat-Stream-Monitor"
  },
  "homepage": "https://github.com/ZababurinSergei/Chat-Stream-Monitor#readme",
  "bugs": {
    "url": "https://github.com/ZababurinSergei/Chat-Stream-Monitor/issues"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.22.0",
    "estree-walker": "^3.0.3",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@repo/eslint-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-unicorn": "^66.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "Directory/ast-analyzer/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "Directory/ast-analyzer/**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "packages/**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "tooling/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "18.19.0",
    "pnpm": "8.15.0"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  }
}
