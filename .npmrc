# Запретить использование npm/yarn
engine-strict=true

# Использовать pnpm
use-pnpm=true

# Точное соответствие версии
exact=true

# Автоматическая установка peer dependencies
auto-install-peers=true

# Сохранять точные версии
save-exact=true

# Запретить обновление package-lock.json (если кто-то случайно запустит npm)
package-lock=false

# Запретить yarn.lock
yarn-lock=false

# pnpm специфичные настройки
shamefully-hoist=false
strict-peer-dependencies=true

# Линковка workspace пакетов
link-workspace-packages=true
prefer-workspace-packages=true

# Shared store для экономии места
shared-workspace-lockfile=true