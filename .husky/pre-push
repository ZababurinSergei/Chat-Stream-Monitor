#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Validating submodule pushes..."

# Проверяем, что все коммиты подмодулей, на которые ссылается родитель, есть на сервере
if ! git push --recurse-submodules=check --dry-run; then
    echo "❌ Ошибка: Вы пытаетесь запушить родительский репозиторий,"
    echo "но коммиты в подмодулях еще не отправлены на удаленный сервер!"
    echo "Запушьте подмодули (например, через 'mr push') и повторите попытку."
    exit 1
fi