#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ============================================
# COMMIT-MSG HOOK ДЛЯ МОНОРЕПОЗИТОРИЯ
# ============================================
# Проверяет формат сообщения коммита и наличие changeset
# ============================================

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Получаем путь к файлу с сообщением коммита
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# ============================================
# 1. ПРОВЕРКА ФОРМАТА COMMIT MESSAGE
# ============================================

# Регулярное выражение для Conventional Commits
# Формат: type(scope): subject
# types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .{1,100}$"

# Регулярное выражение для Merge коммитов
MERGE_PATTERN="^Merge branch.*|^Merge pull request.*|^Merge tag.*"

# Регулярное выражение для Revert коммитов
REVERT_PATTERN="^Revert \".*\""

# Регулярное выражение для WIP коммитов (разрешены временно)
WIP_PATTERN="^WIP: .*"

# Проверяем, является ли коммит merge, revert или wip
if [[ "$COMMIT_MSG" =~ $MERGE_PATTERN ]] || [[ "$COMMIT_MSG" =~ $REVERT_PATTERN ]]; then
    echo "${GREEN}✅ Merge/Revert commit detected - skipping format check${NC}"
    exit 0
fi

# Проверка на WIP (только для личных веток, не для main/develop)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$COMMIT_MSG" =~ $WIP_PATTERN ]] && [[ "$CURRENT_BRANCH" != "main" ]] && [[ "$CURRENT_BRANCH" != "develop" ]] && [[ "$CURRENT_BRANCH" != "master" ]]; then
    echo "${YELLOW}⚠️  WIP commit detected (allowed only in feature branches)${NC}"
    exit 0
fi

# Проверяем соответствие Conventional Commits
if ! [[ "$COMMIT_MSG" =~ $CONVENTIONAL_PATTERN ]]; then
    echo ""
    echo "${RED}❌ НЕВЕРНЫЙ ФОРМАТ КОММИТА${NC}"
    echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "📝 Сообщение коммита должно соответствовать формату:"
    echo "  ${GREEN}type(scope): subject${NC}"
    echo ""
    echo "🔧 Доступные типы:"
    echo "  ${BLUE}feat${NC}     - новая функциональность"
    echo "  ${BLUE}fix${NC}      - исправление ошибки"
    echo "  ${BLUE}docs${NC}     - изменения документации"
    echo "  ${BLUE}style${NC}    - изменения форматирования (пробелы, точки с запятой и т.д.)"
    echo "  ${BLUE}refactor${NC} - рефакторинг кода (не исправление и не новая функциональность)"
    echo "  ${BLUE}perf${NC}     - изменения производительности"
    echo "  ${BLUE}test${NC}     - добавление или исправление тестов"
    echo "  ${BLUE}build${NC}    - изменения системы сборки или внешних зависимостей"
    echo "  ${BLUE}ci${NC}       - изменения CI/CD конфигурации"
    echo "  ${BLUE}chore${NC}    - прочие изменения (обновление конфигов, etc)"
    echo "  ${BLUE}revert${NC}   - откат предыдущего коммита"
    echo ""
    echo "📌 Примеры правильных коммитов:"
    echo "  ${GREEN}feat(ast-analyzer): add new refactor mode${NC}"
    echo "  ${GREEN}fix(shared-types): resolve type mismatch in Config interface${NC}"
    echo "  ${GREEN}docs: update README with workspace setup${NC}"
    echo "  ${GREEN}chore: update .gitignore for monorepo${NC}"
    echo "  ${GREEN}test(ast-analyzer): add unit tests for ModuleExtractor${NC}"
    echo "  ${GREEN}ci: add GitHub Actions workflow${NC}"
    echo ""
    echo "📖 Scopes (опционально):"
    echo "  - ast-analyzer   - изменения в Directory/ast-analyzer"
    echo "  - shared-types   - изменения в packages/shared-types"
    echo "  - monorepo       - изменения корневых конфигов"
    echo "  - tooling        - изменения в tooling/"
    echo "  - deps           - обновление зависимостей"
    echo ""
    echo "❌ Ваше сообщение:"
    echo "  ${RED}$COMMIT_MSG${NC}"
    echo ""
    echo "💡 Попробуйте:"
    echo "  git commit -m \"type(scope): ваше сообщение\""
    echo ""
    echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 1
fi

echo "${GREEN}✅ Commit message format: OK${NC}"

# ============================================
# 2. ПРОВЕРКА ДЛИНЫ СООБЩЕНИЯ
# ============================================

# Удаляем type(scope): из сообщения для проверки длины
SUBJECT=$(echo "$COMMIT_MSG" | sed -E 's/^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: //')

if [ ${#SUBJECT} -gt 100 ]; then
    echo ""
    echo "${YELLOW}⚠️  WARNING: Subject line is too long (${#SUBJECT}/100 characters)${NC}"
    echo "   ${SUBJECT}"
    echo "   💡 Try to keep it under 100 characters"
    echo ""
    # Предупреждение, но не блокируем коммит
fi

# ============================================
# 3. ПРОВЕРКА НА BRANCH (опционально)
# ============================================

# Получаем текущую ветку
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Проверяем соответствие branch и commit type
if [[ "$CURRENT_BRANCH" == "main" ]] || [[ "$CURRENT_BRANCH" == "master" ]] || [[ "$CURRENT_BRANCH" == "develop" ]]; then
    # На главных ветках запрещаем WIP и фиксы без issue
    if [[ "$COMMIT_MSG" =~ ^fix\( ]] && [[ ! "$COMMIT_MSG" =~ \(#[0-9]+\) ]]; then
        echo ""
        echo "${YELLOW}⚠️  WARNING: Fix commit on $CURRENT_BRANCH without issue reference${NC}"
        echo "   💡 Add issue number: fix(scope): message (#123)"
        echo ""
    fi
fi

# ============================================
# 4. ПРОВЕРКА CHANGESET (для изменяющих код коммитов)
# ============================================

# Определяем, нужно ли проверять changeset
# Только для коммитов, которые изменяют пакеты (feat, fix, perf, refactor)
HAS_CHANGESET_FILE=$(git diff --cached --name-only | grep -E "\.changeset/.*\.md" | wc -l)
IS_CODE_CHANGE=$(echo "$COMMIT_MSG" | grep -E "^(feat|fix|perf|refactor)")

# Проверяем, не является ли это коммитом changeset'а
IS_CHANGESET_COMMIT=$(echo "$COMMIT_MSG" | grep -E "^(chore|docs).*changeset")

if [[ $IS_CODE_CHANGE ]] && [[ $HAS_CHANGESET_FILE -eq 0 ]] && [[ ! $IS_CHANGESET_COMMIT ]]; then
    # Игнорируем для веток без изменений в packages/
    HAS_PACKAGE_CHANGES=$(git diff --cached --name-only | grep -E "^(Directory/ast-analyzer|packages/)" | wc -l)

    if [[ $HAS_PACKAGE_CHANGES -gt 0 ]]; then
        echo ""
        echo "${YELLOW}⚠️  WARNING: You changed packages but didn't add a changeset${NC}"
        echo "   💡 Run ${GREEN}pnpm changeset${NC} to create a changeset"
        echo "   📖 More info: https://github.com/changesets/changesets"
        echo ""
        # Не блокируем коммит, только предупреждение
    fi
fi

# ============================================
# 5. ПРОВЕРКА НАВИГАЦИИ ПО СТРУКТУРЕ
# ============================================

# Подсказка о правильном scope для измененных файлов
CHANGED_FILES=$(git diff --cached --name-only)

if echo "$CHANGED_FILES" | grep -q "^Directory/ast-analyzer/"; then
    if ! echo "$COMMIT_MSG" | grep -q "(ast-analyzer)"; then
        echo ""
        echo "${BLUE}💡 Hint: You changed files in ast-analyzer${NC}"
        echo "   Consider using scope: ${GREEN}feat(ast-analyzer): message${NC}"
        echo ""
    fi
fi

if echo "$CHANGED_FILES" | grep -q "^packages/shared-types/"; then
    if ! echo "$COMMIT_MSG" | grep -q "(shared-types)"; then
        echo ""
        echo "${BLUE}💡 Hint: You changed files in shared-types${NC}"
        echo "   Consider using scope: ${GREEN}feat(shared-types): message${NC}"
        echo ""
    fi
fi

if echo "$CHANGED_FILES" | grep -q "^tooling/"; then
    if ! echo "$COMMIT_MSG" | grep -q "(tooling)"; then
        echo ""
        echo "${BLUE}💡 Hint: You changed files in tooling/${NC}"
        echo "   Consider using scope: ${GREEN}chore(tooling): message${NC}"
        echo ""
    fi
fi

# ============================================
# 6. ПРОВЕРКА НА ЗАБЫТЫЕ ДОКУМЕНТАЦИЮ
# ============================================

if echo "$COMMIT_MSG" | grep -q "^feat"; then
    # Проверяем, обновлена ли документация
    HAS_DOCS_CHANGE=$(echo "$CHANGED_FILES" | grep -E "README|docs/" | wc -l)

    if [[ $HAS_DOCS_CHANGE -eq 0 ]] && [[ ! "$COMMIT_MSG" =~ no-docs ]]; then
        echo ""
        echo "${YELLOW}⚠️  WARNING: New feature added without documentation update${NC}"
        echo "   💡 Update README.md or add docs/"
        echo "   💡 Add 'no-docs' to commit message to suppress this warning"
        echo ""
    fi
fi

# ============================================
# 7. ЗАВЕРШЕНИЕ
# ============================================

echo "${GREEN}✅ Commit-msg hook passed!${NC}"
echo ""

exit 0