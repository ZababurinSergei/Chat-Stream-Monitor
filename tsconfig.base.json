{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "noEmit": false,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noFallthroughCasesInSwitch": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,

    "allowJs": true,
    "checkJs": false,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@newkind/ast-analyzer": ["./Directory/ast-analyzer/src/index.ts"],
      "@newkind/ast-analyzer/*": ["./Directory/ast-analyzer/src/*"],
      "@newkind/ast-analyzer/cli": ["./Directory/ast-analyzer/src/cli.ts"],
      "@newkind/ast-analyzer/refactor": [
        "./Directory/ast-analyzer/src/refactor/index.ts"
      ],
      "@newkind/ast-analyzer/semantic": [
        "./Directory/ast-analyzer/src/semantic/index.ts"
      ],
      "@newkind/ast-analyzer/formal": [
        "./Directory/ast-analyzer/src/formal/index.ts"
      ],

      "@newkind/shared-types": ["./packages/shared-types/src/index.ts"],
      "@newkind/shared-types/*": ["./packages/shared-types/src/*"],

      "@repo/eslint-config": ["./tooling/eslint-config/index.js"],
      "@repo/prettier-config": ["./tooling/prettier-config/index.js"],
      "@repo/typescript-config": ["./tooling/typescript-config/base.json"],
      "@directory/*": ["./Directory/src/*"],
      "@packages/*": ["./packages/src/*"]
    },

    "types": ["node", "vitest/globals"],

    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },

  "include": [
    // ТОЛЬКО ast-analyzer из папки Directory
    "Directory/ast-analyzer/src/**/*.ts",
    "Directory/ast-analyzer/src/**/*.tsx",
    "Directory/ast-analyzer/src/**/*.js",
    "Directory/ast-analyzer/src/**/*.jsx",
    "Directory/ast-analyzer/src/**/*.vue",
    "Directory/ast-analyzer/src/**/*.mjs",
    "Directory/ast-analyzer/src/**/*.cjs",

    // Остальные пакеты
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/src/**/*.js",
    "packages/*/src/**/*.jsx",
    "tooling/*/**/*.ts",
    "tooling/*/**/*.js",
    "*.ts",
    "*.js",
    "*.mjs",
    "*.cjs",
    "*.d.ts"
  ],

  "exclude": [
    // ИСКЛЮЧАЕМ все остальные Directory/* (кроме ast-analyzer)
    "Directory",
    // Исключаем системные папки внутри ast-analyzer
    "Directory/ast-analyzer/node_modules",
    "Directory/ast-analyzer/dist",
    "Directory/ast-analyzer/build",
    "Directory/ast-analyzer/coverage",
    "Directory/ast-analyzer/.turbo",
    "Directory/ast-analyzer/modules",

    // Остальные исключения
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".turbo",
    ".next",
    "out",
    "**/__tests__/fixtures",
    "**/__tests__/temp",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "packages/*/dist",
    "packages/*/build",
    "packages/*/coverage",
    "packages/*/node_modules",
    "tooling/*/node_modules",
    "**/*.backup.*",
    "**/*.tmp",
    "**/*.swp"
  ],

  "compileOnSave": false,
  "typesAcquisition": {
    "enable": false
  }
}
