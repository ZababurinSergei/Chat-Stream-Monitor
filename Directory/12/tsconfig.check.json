{
  "compilerOptions": {
    /* Основные настройки - исправляем target и lib */
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM"
    ],

    /* Строгие проверки (оставляем) */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "allowImportingTsExtensions": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "alwaysStrict": true,
    "skipLibCheck": true,

    /* Настройки модулей */
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,      // Проверяет неиспользуемые локальные переменные и импорты
    "noUnusedParameters": false,  // Проверяет неиспользуемые параметры функций
    /* Куда и что компилируем */
    "outDir": "./dist",
    "rootDir": "./ts",
    "baseUrl": "./",
    "typeRoots": [
      "./node_modules/@webgpu/types",
      "./node_modules/@types",
      "../orillusion/types"
    ],
    "types": [
      "node",
      "dat.gui",
      "gl-matrix"
    ],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "ts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "ts/test",
    "../orillusion"
  ]
}