{
  "name": "@repo/eslint-config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./react": {
      "import": "./react.js",
      "types": "./react.d.ts"
    },
    "./vue": {
      "import": "./vue.js",
      "types": "./vue.d.ts"
    },
    "./node": {
      "import": "./node.js",
      "types": "./node.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --config index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "react.js",
    "react.d.ts",
    "vue.js",
    "vue.d.ts",
    "node.js",
    "node.d.ts"
  ],
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "monorepo",
    "code-quality",
    "linting"
  ],
