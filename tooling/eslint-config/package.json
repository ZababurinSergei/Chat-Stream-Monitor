    "directory": "tooling/eslint-config"
  },
  "homepage": "https://github.com/ZababurinSergei/Chat-Stream-Monitor/tree/main/tooling/eslint-config",
  "bugs": {
    "url": "https://github.com/ZababurinSergei/Chat-Stream-Monitor/issues"
