digraph "Dependency Graph" {
  rankdir=LR;
  splines=true;
  node [shape=box, style="filled,rounded", color="#4f46e5", fontname="Arial", fillcolor="#f3f4f6", fontcolor="#1f2937", penwidth=1];
  edge [color="#9ca3af", arrowhead=vee, penwidth=1];
  "FileSystemScanner.js" [fillcolor="#4f46e5", fontcolor="#ffffff", penwidth=2, label="⭐ FileSystemScanner.js"];
  "__dirname" -> "__filename";
  "getCurrentLanguage" -> "language";
  "getCurrentLanguage" -> "config";
  "language" -> "config";
  "t" -> "lang";
  "t" -> "getCurrentLanguage";
  "t" -> "languageTemplates";
  "lang" -> "getCurrentLanguage";
  "getLocalizedDescription" -> "lang";
  "getLocalizedDescription" -> "getCurrentLanguage";
  "getLocalizedDescription" -> "t";
  "isExcluded" -> "excludePatterns";
  "isExcluded" -> "config";
  "isExcluded" -> "respectExcludePatterns";
  "isExcluded" -> "excludedDirs";
  "isExcluded" -> "excludedFiles";
  "isExcluded" -> "regexPattern";
  "isExcluded" -> "regex";
  "excludePatterns" -> "config";
  "respectExcludePatterns" -> "config";
  "excludedDirs" -> "excludePatterns";
  "excludedFiles" -> "excludePatterns";
  "regex" -> "regexPattern";
  "getDefaultConfig" -> "excludePatterns";
  "getDefaultConfig" -> "maxDepth";
  "getDefaultConfig" -> "respectExcludePatterns";
  "getDefaultConfig" -> "language";
  "getDefaultConfig" -> "supportedExtensions";
  "getDefaultConfig" -> "DEFAULT_SUPPORTED_EXTENSIONS";
  "getDefaultConfig" -> "specialFiles";
  "getDefaultConfig" -> "DEFAULT_SPECIAL_FILES";
  "isSupportedFile" -> "supportedExtensions";
  "isSupportedFile" -> "config";
  "isSupportedFile" -> "DEFAULT_SUPPORTED_EXTENSIONS";
  "isSupportedFile" -> "specialFiles";
  "isSupportedFile" -> "DEFAULT_SPECIAL_FILES";
  "supportedExtensions" -> "config";
  "supportedExtensions" -> "DEFAULT_SUPPORTED_EXTENSIONS";
  "specialFiles" -> "config";
  "specialFiles" -> "DEFAULT_SPECIAL_FILES";
  "fileParsers" -> "escapeContent";
  "fileParsers" -> "escapeHtmlContent";
  "escapeHtmlContent" -> "escapeContent";
  "scanDirectory" -> "maxDepth";
  "scanDirectory" -> "config";
  "scanDirectory" -> "getDirectoryDescription";
  "scanDirectory" -> "lang";
  "scanDirectory" -> "getCurrentLanguage";
  "scanDirectory" -> "isExcluded";
  "scanDirectory" -> "processFile";
  "scanDirectory" -> "isSupportedFile";
  "maxDepth" -> "config";
  "processFile" -> "fileParsers";
  "processFile" -> "escapeContent";
  "getDirectoryDescription" -> "lang";
  "getDirectoryDescription" -> "getCurrentLanguage";
  "getDirectoryDescription" -> "descriptions";
  "getDirectoryDescription" -> "config";
  "descriptions" -> "config";
  "descriptions" -> "lang";
}
