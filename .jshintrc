{
  "esversion": 2022,
  "node": true,
  "module": true,

  "globals": {
    "import": true,
    "export": true,
    "describe": true,
    "it": true,
    "expect": true,
    "beforeEach": true,
    "afterEach": true,
    "vi": true
  },

  "bitwise": true,
  "camelcase": true,
  "curly": true,
  "eqeqeq": true,
  "forin": true,
  "freeze": true,
  "immed": true,
  "indent": 2,
  "latedef": "nofunc",
  "maxcomplexity": 20,
  "maxdepth": 5,
  "maxlen": 120,
  "maxparams": 5,
  "maxstatements": 50,
  "newcap": true,
  "noarg": true,
  "noempty": true,
  "nonbsp": true,
  "nonew": true,
  "plusplus": false,
  "quotmark": "single",
  "shadow": false,
  "strict": false,
  "trailing": true,
  "undef": true,
  "unused": true,
  "varstmt": false,

  "boss": false,
  "debug": false,
  "devel": false,
  "evil": false,
  "expr": true,
  "funcscope": false,
  "globalstrict": false,
  "lastsemic": false,
  "laxbreak": false,
  "laxcomma": false,
  "loopfunc": true,
  "moz": false,
  "multistr": false,
  "notypeof": false,
  "proto": false,
  "scripturl": false,
  "smarttabs": false,
  "sub": true,
  "supernew": false,
  "validthis": false,

  "browser": false,
  "jquery": false,
  "nonstandard": false,
  "worker": false
}