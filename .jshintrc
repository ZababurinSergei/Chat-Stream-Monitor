{
  "esversion": 11,
  "node": true,
  "module": true,
  "browser": false,
  "maxerr": 50,
  "asi": true,
  "bitwise": true,
  "boss": true,
  "curly": true,
  "eqeqeq": true,
  "eqnull": true,
  "evil": true,
  "expr": true,
  "funcscope": true,
  "globalstrict": true,
  "latedef": false,
  "maxlen": false,
  "newcap": true,
  "noarg": true,
  "nonbsp": true,
  "nonew": true,
  "shadow": false,
  "sub": true,
  "trailing": true,
  "undef": true,
  "unused": false,
  "validthis": true,
  "varstmt": false,
  "proto": true,
  "iterator": true,
  "supernew": true,
  "noyield": true,
  "notypeof": true,
  "quotmark": false,
  "laxbreak": true,
  "predef": [
    "__filename",
    "__dirname",
    "describe",
    "it",
    "expect",
    "beforeEach",
    "afterEach",
    "process",
    "console",
    "module",
    "require",
    "exports"
  ]
}